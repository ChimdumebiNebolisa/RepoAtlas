# RepoAtlas environment configuration.
# Copy to `.env.local` for local development. All values are OPTIONAL for a
# default local (filesystem storage) run — no secrets are required to start.
#
# NEVER commit real secret values. Do not add a GitHub token here: RepoAtlas
# analyzes only public repositories and must never attach a server-owned token
# to a user-supplied repository request.

# --- Storage ---
# Directory for filesystem-backed report/share JSON (default: <project>/reports).
# REPORTS_DIR=./reports

# Vercel Blob static storage token. New Vercel project connections use the
# short-lived VERCEL_OIDC_TOKEN + BLOB_STORE_ID pair automatically; use this
# fallback only for local development or deployments outside Vercel.
# BLOB_READ_WRITE_TOKEN=

# --- Retention ---
# Report time-to-live in days (default: 30, or 7 when a Blob token is set).
# REPORT_TTL_DAYS=30
# Maximum number of retained reports (default: 100).
# REPORT_MAX_COUNT=100

# --- Cron cleanup auth ---
# Shared secret required for POST /api/cron/cleanup. In production the cleanup
# mutation fails closed when this is not configured.
# CRON_SECRET=

# --- Rate limiting ---
# Max /api/analyze requests per minute per client (0 or unset disables).
# ANALYZE_RATE_LIMIT_PER_MIN=
# Max concurrent in-flight analyses.
# MAX_CONCURRENT_ANALYSES=
